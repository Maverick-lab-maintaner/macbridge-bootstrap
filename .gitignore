# MacBridge bootstrap logs — keep directory, ignore contents
logs/*.log
logs/*
!logs/.gitkeep

# Watcher state files (version tracking cache)
.cache/

# Go build artifacts (binary only, not source directory)
/macbridge
/macbridge.exe

# Release build outputs — keep the Homebrew formula template
dist/*
!dist/homebrew/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/

# Radar generated outputs — keep the directory, ignore run artifacts
ops/radar/output/*
!ops/radar/output/.gitkeep
